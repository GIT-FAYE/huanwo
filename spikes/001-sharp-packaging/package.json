{
  "name": "huanwo-spike-001",
  "version": "0.0.1",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --win portable --dir",
    "dist": "electron-builder --win nsis"
  },
  "build": {
    "appId": "com.huanwo.spike",
    "productName": "HuanWo-Spike",
    "win": {
      "target": [
        "nsis"
      ],
      "icon": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "main.js",
      "node_modules/**/*"
    ],
    "asar": true,
    "asarUnpack": [
      "**/*.node",
      "**/sharp/**"
    ]
  },
  "devDependencies": {
    "electron": "^36.3.1",
    "electron-builder": "^26.0.12"
  },
  "dependencies": {
    "sharp": "^0.34.5"
  }
}
